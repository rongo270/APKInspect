# Normalise line endings so the repo behaves the same on every machine.
* text=auto eol=lf

# Windows launchers MUST keep CRLF or cmd.exe can misbehave on checkout.
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Unix launchers MUST keep LF or macOS/Linux can't run them.
*.command text eol=lf
*.sh      text eol=lf

# Binary assets - never touch line endings.
*.png binary
*.ico binary
*.apk binary
*.aab binary
