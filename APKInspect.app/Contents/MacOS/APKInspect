#!/bin/bash
# APKInspect.app launcher. Starts the local GUI from the APKInspect folder
# that contains this .app. Keep the .app inside that folder.
cd "$(cd "$(dirname "$0")/../../.." && pwd)" || exit 1

# Find a Python 3.8+ interpreter. Apps launched from Finder get a minimal
# PATH, so check the usual install locations explicitly too.
ok() { "$1" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 8) else 1)' >/dev/null 2>&1; }
PY=""
for c in python3 python \
         /usr/local/bin/python3 /opt/homebrew/bin/python3 \
         /Library/Frameworks/Python.framework/Versions/Current/bin/python3 \
         /usr/bin/python3; do
  if ok "$c"; then PY="$c"; break; fi
done
if [ -z "$PY" ]; then
  for c in /Library/Frameworks/Python.framework/Versions/3.*/bin/python3; do
    if [ -x "$c" ] && ok "$c"; then PY="$c"; break; fi
  done
fi

if [ -z "$PY" ]; then
  osascript -e 'display dialog "APKInspect needs Python 3.8 or newer. Opening the download page now." buttons {"OK"} default button 1 with title "APKInspect"' >/dev/null 2>&1
  open "https://www.python.org/downloads/"
  exit 1
fi

exec "$PY" -m apkinspect.web
